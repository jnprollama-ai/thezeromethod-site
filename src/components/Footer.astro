---

<footer class="bg-navy-900 border-t border-navy-800">
  <div class="max-w-7xl mx-auto px-6 lg:px-8 py-12 lg:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 lg:gap-12">
      <!-- Brand -->
      <div class="lg:col-span-2">
        <a href="/" class="flex items-center space-x-2 mb-4">
          <div class="w-10 h-10 bg-gradient-to-br from-gold-400 to-gold-600 rounded-lg flex items-center justify-center">
            <span class="text-navy-900 font-bold text-xl">0</span>
          </div>
          <span class="text-2xl font-bold text-white">
            Zero<span class="text-gold-500">Method</span>
          </span>
        </a>
        <p class="text-navy-400 text-sm leading-relaxed mb-6 max-w-sm">
          25 AI prompts + 10 email templates. Copy-paste ready resources that save you 5 hours every week.
        </p>
        <!-- Social Links - Coming Soon -->
        <div class="flex items-center space-x-4">
          <span class="text-navy-500 text-sm">Social links coming soon</span>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-white font-semibold mb-4">Product</h3>
        <ul class="space-y-3">
          {footerLinks.product.map(link => (
            <li>
              <a href={link.href} class="text-navy-400 hover:text-gold-500 text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Company</h3>
        <ul class="space-y-3">
          {footerLinks.company.map(link => (
            <li>
              <a href={link.href} class="text-navy-400 hover:text-gold-500 text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h3 class="text-white font-semibold mb-4">Legal</h3>
        <ul class="space-y-3">
          {footerLinks.legal.map(link => (
            <li>
              <a href={link.href} class="text-navy-400 hover:text-gold-500 text-sm transition-colors duration-200">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom -->
    <div class="mt-12 pt-8 border-t border-navy-800">
      <div class="flex flex-col md:flex-row items-center justify-between space-y-4 md:space-y-0">
        <p class="text-navy-400 text-sm">
          © {currentYear} Zero Method. All rights reserved.
        </p>
        <p class="text-navy-500 text-xs">
          Built with 🌀 by Zero
        </p>
      </div>
    </div>
  </div>
</footer>
