---
const footerLinks = {
  Product: [
    { href: "/product", label: "Features" },
    { href: "/product", label: "Pricing" },
    { href: "/blog", label: "Blog" }
  ],
  Company: [
    { href: "/blog", label: "Blog" },
    { href: "mailto:support@thezeromethod.com", label: "Contact" }
  ],
  Legal: [
    { href: "/privacy", label: "Privacy Policy" },
    { href: "/terms", label: "Terms of Service" }
  ]
};
---

<footer style="padding: 4rem 0; background: var(--color-bg-secondary); border-top: 1px solid var(--color-border);">
  <div class="container">
    <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 3rem; margin-bottom: 3rem;">
      <!-- Brand -->
      <div>
        <div style="display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1rem;">
          <span style="font-family: var(--font-heading); font-size: 1.5rem; font-weight: 600; color: var(--color-text);">0</span>
          <span style="font-family: var(--font-heading); font-size: 1.25rem; font-weight: 500; color: var(--color-text);">ZeroMethod</span>
        </div>
        <p style="color: var(--color-text-muted); font-size: 0.9375rem; max-width: 280px; line-height: 1.7;">
          25 AI prompts + 10 email templates. Copy-paste ready resources that save you hours every week.
        </p>
      </div>
      
      <!-- Links -->
      {Object.entries(footerLinks).map(([category, links]) => (
        <div>
          <h4 style="font-family: var(--font-heading); font-size: 0.875rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 1rem;">
            {category}
          </h4>
          <ul style="list-style: none; display: flex; flex-direction: column; gap: 0.75rem;">
            {links.map(link => (
              <li>
                <a 
                  href={link.href} 
                  style="color: var(--color-text-secondary); text-decoration: none; font-size: 0.9375rem; transition: color 0.2s;"
                  class="footer-link"
                >
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
    
    <div style="display: flex; justify-content: space-between; align-items: center; padding-top: 2rem; border-top: 1px solid var(--color-border);">
      <p style="color: var(--color-text-muted); font-size: 0.875rem;">
        © 2026 Zero Method. All rights reserved.
      </p>
      
      <p style="color: var(--color-text-muted); font-size: 0.875rem;">
        Built with 🌀 by Zero
      </p>
    </div>
  </div>
</footer>

<style>
  .footer-link:hover {
    color: var(--color-text) !important;
  }
</style>