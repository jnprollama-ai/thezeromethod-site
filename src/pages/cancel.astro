---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Payment Cancelled | Zero Method";
const description = "Your payment was cancelled. No worries — you can try again whenever you're ready.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="pt-32 pb-20 min-h-screen">
    <div class="max-w-2xl mx-auto px-6 lg:px-8">
      <!-- Cancelled Card -->
      <div class="bg-navy-900 rounded-2xl border border-navy-800 p-8 lg:p-12 text-center">
        <!-- Cancelled Icon -->
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-navy-800 mb-6">
          <svg class="w-10 h-10 text-navy-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold text-white mb-4">
          Payment Cancelled
        </h1>
        <p class="text-navy-400 text-lg mb-8 max-w-lg mx-auto">
          No worries! Your payment was cancelled and no charges were made. 
          You can complete your purchase whenever you're ready.
        </p>

        <!-- Retry Options -->
        <div class="space-y-4">
          <a
            href="/product#pricing"
            class="inline-flex items-center px-8 py-4 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold text-lg rounded-lg transition-all duration-200"
          >
            Try Again
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
          </a>

          <p class="text-navy-500 text-sm">
            or
          </p>

          <a
            href="mailto:support@thezeromethod.com?subject=Questions%20About%20Zero%20Method"
            class="inline-flex items-center text-gold-500 hover:text-gold-400 font-medium transition-colors"
          >
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Have questions? Contact us
          </a>
        </div>
      </div>

      <!-- Still Interested? -->
      <div class="mt-8 bg-gradient-to-br from-navy-800 to-navy-900 rounded-2xl border border-navy-700 p-8">
        <h2 class="text-xl font-bold text-white mb-4 text-center">
          Still Interested?
        </h2>
        <p class="text-navy-400 text-center mb-6">
          Try 5 of our most popular prompts for free before you buy.
        </p>
        <div class="text-center">
          <a
            href="/#free-prompts"
            class="inline-flex items-center px-6 py-3 bg-navy-800 hover:bg-navy-700 text-white font-semibold rounded-lg border border-navy-700 transition-colors duration-200"
          >
            Get 5 Free Prompts
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
        </div>
      </div>

      <!-- Trust Badges -->
      <div class="mt-8 flex items-center justify-center space-x-6 text-navy-500 text-sm">
        <div class="flex items-center">
          <svg class="w-5 h-5 text-gold-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
          </svg>
          <span>Secure Payment</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 text-gold-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
          </svg>
          <span>30-Day Guarantee</span>
        </div>
        <div class="flex items-center">
          <svg class="w-5 h-5 text-gold-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
          </svg>
          <span>5,000+ Users</span>
        </div>
      </div>

      <!-- Back to Home -->
      <div class="text-center mt-8">
        <a
          href="/"
          class="inline-flex items-center text-navy-400 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Homepage
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>