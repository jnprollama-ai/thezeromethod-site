---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Zero Method — AI Prompts That Actually Work";
const description = "25 battle-tested AI prompts + 10 email templates. Save hours every week with proven workflows.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <!-- Hero -->
    <section class="min-h-screen flex items-center justify-center pt-32 pb-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <p class="text-sm font-medium text-amber-400 mb-6">25 AI Prompts + 10 Email Templates — $19</p>
        
        <h1 class="text-6xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[0.95] mb-8">
          <span class="gradient-text">The prompts that</span><br>
          <span class="gradient-gold">actually work.</span>
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-400 max-w-2xl mx-auto mb-10 leading-relaxed">
          Battle-tested AI prompts and email templates that save you hours every week. No theory. Just results.
        </p>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <a href="/product" class="btn-primary">
            Get the pack — $19
            <span>→</span>
          </a>
          <a href="#features" class="px-8 py-4 rounded-full text-sm border border-white/20 text-white hover:bg-white/5 transition-colors">
            Learn more
          </a>
        </div>
        
        <div class="mt-12 flex items-center justify-center gap-6 text-sm text-gray-500">
          <span>✓ 30-day guarantee</span>
          <span>✓ Instant download</span>
          <span>✓ One-time purchase</span>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section id="features" class="py-24 bg-[#141418]">
      <div class="max-w-6xl mx-auto px-6">
        <div class="text-center mb-16">
          <p class="text-sm font-medium text-amber-400 mb-4">What's Inside</p>
          <h2 class="text-4xl md:text-5xl font-semibold tracking-tight gradient-text mb-4">
            25 Prompts. 5 Categories.
          </h2>
          <p class="text-gray-400 text-lg">Every prompt tested, refined, and ready to use.</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Email & Communication</span>
              <span class="text-amber-400 text-sm font-mono">5</span>
            </div>
            <p class="text-gray-400 text-sm">Professional emails that get responses</p>
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Reports & Documentation</span>
              <span class="text-blue-400 text-sm font-mono">5</span>
            </div>
            <p class="text-gray-400 text-sm">Clear documentation from any input</p>
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Content Creation</span>
              <span class="text-emerald-400 text-sm font-mono">5</span>
            </div>
            <p class="text-gray-400 text-sm">Blog posts, social, marketing copy</p>
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Productivity</span>
              <span class="text-violet-400 text-sm font-mono">5</span>
            </div>
            <p class="text-gray-400 text-sm">Organization and task automation</p>
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Research & Analysis</span>
              <span class="text-cyan-400 text-sm font-mono">5</span>
            </div>
            <p class="text-gray-400 text-sm">Data synthesis and insights</p>
          </div>

          <div class="card">
            <div class="flex items-center justify-between mb-3">
              <span class="text-lg font-medium">Email Templates</span>
              <span class="text-rose-400 text-sm font-mono">10</span>
            </div>
            <p class="text-gray-400 text-sm">Cold outreach, follow-ups, meetings</p>
          </div>
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section class="py-24">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <p class="text-sm font-medium text-amber-400 mb-4">How It Works</p>
            <h2 class="text-4xl md:text-5xl font-semibold tracking-tight gradient-text mb-6">
              Three steps.<br>No learning curve.
            </h2>
            <p class="text-gray-400 text-lg">
              Get started in minutes. No complicated setup. Just copy, paste, and execute.
            </p>
          </div>

          <div class="space-y-8">
            <div class="flex items-baseline gap-6 border-b border-white/10 pb-8">
              <span class="text-5xl font-bold text-white/10">01</span>
              <div>
                <h3 class="text-xl font-semibold mb-1">Download</h3>
                <p class="text-gray-400">PDF + Markdown files. Instant delivery.</p>
              </div>
            </div>

            <div class="flex items-baseline gap-6 border-b border-white/10 pb-8">
              <span class="text-5xl font-bold text-white/10">02</span>
              <div>
                <h3 class="text-xl font-semibold mb-1">Find Your Prompt</h3>
                <p class="text-gray-400">5 categories, fully indexed. Find what you need in 30 seconds.</p>
              </div>
            </div>

            <div class="flex items-baseline gap-6">
              <span class="text-5xl font-bold text-white/10">03</span>
              <div>
                <h3 class="text-xl font-semibold mb-1">Paste & Execute</h3>
                <p class="text-gray-400">Customize the brackets. Run it. Save 30–60 minutes per task.</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="py-24 bg-[#141418]">
      <div class="max-w-6xl mx-auto px-6">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold gradient-gold mb-2">89%</div>
            <p class="text-gray-400 text-sm">feel in control<br>within 2 weeks</p>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold gradient-gold mb-2">4.2h</div>
            <p class="text-gray-400 text-sm">reclaimed per day<br>on average</p>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold gradient-gold mb-2">32</div>
            <p class="text-gray-400 text-sm">commitments<br>eliminated on avg</p>
          </div>
          <div class="text-center">
            <div class="text-5xl md:text-6xl font-bold gradient-gold mb-2">97%</div>
            <p class="text-gray-400 text-sm">would recommend<br>to a peer</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section class="py-24">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <blockquote class="text-2xl md:text-3xl font-medium leading-relaxed gradient-text mb-8">
          "I used to spend 45 minutes writing executive summaries. Now it takes 8. That's not a feature — that's a refund on my afternoon."
        </blockquote>
        <div class="flex items-center justify-center gap-4">
          <div class="w-12 h-12 rounded-full bg-gradient-to-br from-amber-400 to-orange-500 flex items-center justify-center text-black font-bold">
            SK
          </div>
          <div class="text-left">
            <div class="font-medium">Sarah K.</div>
            <div class="text-sm text-gray-400">Operations Director</div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section class="py-24 bg-[#141418]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <p class="text-sm font-medium text-amber-400 mb-4">Simple Pricing</p>
        <div class="mb-6">
          <span class="text-6xl md:text-7xl font-bold">$19</span>
          <span class="text-xl text-gray-400 ml-2">one-time</span>
        </div>
        <p class="text-gray-400 mb-10 text-lg">No subscription. No upsells. Just $19 once.</p>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-10 text-left max-w-lg mx-auto">
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">25 AI Prompts</span></div>
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">10 Email Templates</span></div>
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">PDF + Markdown</span></div>
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">1 Year Updates</span></div>
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">30-Day Guarantee</span></div>
          <div class="flex items-center gap-3"><span class="text-amber-400">✓</span><span class="text-gray-300">Instant Download</span></div>
        </div>

        <a href="/product" class="btn-primary text-lg">
          Get the Pack — $19
          <span>→</span>
        </a>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-24">
      <div class="max-w-3xl mx-auto px-6">
        <h2 class="text-3xl md:text-4xl font-semibold text-center mb-12">Questions?</h2>
        
        <div class="space-y-4">
          <div class="bg-[#141418] rounded-xl p-6 border border-white/5">
            <h3 class="font-semibold mb-2">What's actually included?</h3>
            <p class="text-gray-400 text-sm leading-relaxed">You get 25 AI prompts organized into 5 categories plus 10 professional email templates. Everything is delivered as both PDF and Markdown files for immediate use.</p>
          </div>

          <div class="bg-[#141418] rounded-xl p-6 border border-white/5">
            <h3 class="font-semibold mb-2">Do I need technical skills?</h3>
            <p class="text-gray-400 text-sm leading-relaxed">Not at all. If you can copy and paste, you can use these prompts. Simply copy the template, fill in your details, and paste into any AI tool.</p>
          </div>

          <div class="bg-[#141418] rounded-xl p-6 border border-white/5">
            <h3 class="font-semibold mb-2">What if I'm not satisfied?</h3>
            <p class="text-gray-400 text-sm leading-relaxed">30-day money-back guarantee. Email support@thezeromethod.com within 30 days for a full refund. No forms, no questions asked.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="py-24 bg-[#141418]">
      <div class="max-w-3xl mx-auto px-6 text-center">
        <h2 class="text-4xl md:text-5xl font-bold tracking-tight gradient-text mb-6">
          Stop writing prompts from scratch.
        </h2>
        <p class="text-gray-400 mb-8 text-lg">
          Get 25 proven prompts and 10 templates. Start saving time today.
        </p>
        <a href="/product" class="btn-primary text-lg">
          Get the Pack — $19
          <span>→</span>
        </a>
      </div>
    </section>
  </main>

  <Footer />
</Layout>