---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Zero Method — AI Prompts That Work";
const description = "25 battle-tested prompts + 10 email templates. Save hours every week with proven AI workflows.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main>
    <!-- Hero -->
    <section class="hero" style="padding: 8rem 0; background: var(--color-bg);">
      <div class="container">
        <div style="max-width: 900px;">
          <p style="color: var(--color-copper); font-family: var(--font-mono); font-size: 0.875rem; text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1.5rem;">
            AI Productivity Tools
          </p>
          
          <h1 style="margin-bottom: 1.5rem;">
            The prompts that<br>
            actually work.
          </h1>
          
          <p style="font-size: 1.25rem; color: var(--color-text-secondary); max-width: 600px; margin-bottom: 2.5rem; line-height: 1.7;">
            25 battle-tested AI prompts + 10 email templates. No fluff, no theory—just proven shortcuts that save you hours every week.
          </p>
          
          <div style="display: flex; gap: 1rem; flex-wrap: wrap;">
            <a href="/product" class="btn btn-primary">Get the pack — $19</a>
            <a href="#what-you-get" class="btn btn-secondary">See what's inside</a>
          </div>
          
          <div style="margin-top: 3rem; display: flex; gap: 2rem; font-size: 0.875rem; color: var(--color-text-muted);">
            <span>✓ 30-day guarantee</span>
            <span>✓ Instant download</span>
            <span>✓ One-time purchase</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Problem Section -->
    <section style="padding: 6rem 0; background: var(--color-bg-secondary);">
      <div class="container">
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: center;">
          <div>
            <p style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-copper); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">The Problem</p>
            
            <h2 style="margin-bottom: 1.5rem;">
              73% of professionals waste 2+ hours a day on tasks AI could handle.
            </h2>
            
            <div class="copper-line" style="margin-bottom: 1.5rem;"></div>
            
            <p style="color: var(--color-text-secondary); line-height: 1.8;">
              Writing prompts from scratch. Getting generic outputs. Starting over when sessions reset. There's a better way.
            </p>
          </div>
          
          <div style="display: flex; flex-direction: column; gap: 1.5rem;">
            {[
              { icon: "✗", text: "Generic AI outputs that need complete rewrites" },
              { icon: "✗", text: "Starting over when sessions reset" },
              { icon: "✗", text: "Hours wasted on repetitive tasks" }
            ].map(item => (
              <div style="display: flex; align-items: center; gap: 1rem; padding: 1.25rem; background: var(--color-surface); border-radius: var(--radius-md);">
                <span style="color: #c45c4a; font-size: 1.25rem;">{item.icon}</span>
                <span style="color: var(--color-text-secondary);">{item.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- What's Inside -->
    <section id="what-you-get" style="padding: 8rem 0;">
      <div class="container">
        <div style="text-align: center; max-width: 700px; margin: 0 auto 4rem;">
          <p style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-copper); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">What's Inside</p>
          <h2 style="margin-bottom: 1rem;">25 Prompts. 5 Categories. Zero Fluff.</h2>
          <p style="color: var(--color-text-secondary);">Every prompt is tested, refined, and ready to use.</p>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1.5rem;">
          {[
            { title: "Email & Communication", count: "5 prompts", desc: "Professional emails that get responses" },
            { title: "Reports & Documentation", count: "5 prompts", desc: "Clear documentation from any input" },
            { title: "Content Creation", count: "5 prompts", desc: "Blog posts, social, marketing copy" },
            { title: "Productivity", count: "5 prompts", desc: "Organization and task automation" },
            { title: "Research & Analysis", count: "5 prompts", desc: "Data synthesis and insights" },
            { title: "Email Templates", count: "10 templates", desc: "Cold outreach, follow-ups, meetings" }
          ].map(cat => (
            <div class="card" style="transition: transform 0.2s;">
              <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.75rem;">
                <h3 style="font-size: 1.125rem; font-weight: 500;">{cat.title}</h3>
                <span style="font-family: var(--font-mono); font-size: 0.75rem; color: var(--color-copper); background: var(--color-bg-secondary); padding: 0.25rem 0.5rem; border-radius: var(--radius-sm);">{cat.count}</span>
              </div>
              <p style="color: var(--color-text-muted); font-size: 0.9375rem;">{cat.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- How It Works -->
    <section style="padding: 6rem 0; background: var(--color-bg-secondary);">
      <div class="container">
        <div style="text-align: center; max-width: 700px; margin: 0 auto 4rem;">
          <p style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-copper); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">How It Works</p>
          <h2>Three steps. No learning curve.</h2>
        </div>
        
        <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 3rem;">
          {[
            { num: "01", title: "Download", desc: "Instant delivery. PDF + Markdown files ready to use." },
            { num: "02", title: "Find Your Prompt", desc: "5 categories, all indexed. Find what you need in 30 seconds." },
            { num: "03", title: "Paste & Execute", desc: "Customize the brackets. Run it. Save 30-60 minutes per task." }
          ].map(step => (
            <div style="text-align: center;">
              <div style="font-family: var(--font-heading); font-size: 4rem; font-weight: 600; color: var(--color-copper); opacity: 0.3; margin-bottom: 1rem;">{step.num}</div>
              <h3 style="font-size: 1.25rem; margin-bottom: 0.75rem;">{step.title}</h3>
              <p style="color: var(--color-text-secondary); font-size: 0.9375rem;">{step.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Testimonial -->
    <section style="padding: 8rem 0;">
      <div class="container" style="max-width: 900px;">
        <div style="text-align: center;">
          <div style="font-size: 2rem; color: var(--color-copper); margin-bottom: 1.5rem;">"""</div>
          <blockquote style="font-family: var(--font-heading); font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.4; margin-bottom: 2rem;">
            I used to spend 45 minutes writing executive summaries. Now it takes 8. That's not a feature — that's a refund on my afternoon.
          </blockquote>
          
          <div class="copper-line" style="margin: 0 auto 1.5rem;"></div>
          
          <p style="color: var(--color-text-muted); font-size: 0.9375rem;">— Sarah K., Operations Director</p>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section style="padding: 6rem 0; background: var(--color-bg-secondary);">
      <div class="container" style="max-width: 600px; text-align: center;">
        <p style="font-family: var(--font-mono); font-size: 0.875rem; color: var(--color-copper); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 1rem;">Simple Pricing</p>
        
        <div style="margin-bottom: 1.5rem;">
          <span style="font-family: var(--font-heading); font-size: 4rem; font-weight: 600;">$19</span>
          <span style="color: var(--color-text-muted); margin-left: 0.5rem;">one-time</span>
        </div>
        
        <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">
          No subscription. No upsells. Just $19 once.
        </p>
        
        <ul style="list-style: none; text-align: left; max-width: 400px; margin: 0 auto 2rem;">
          {[
            "25 AI Prompts across 5 categories",
            "10 professional email templates",
            "PDF + Markdown formats",
            "1 year of free updates",
            "30-day money-back guarantee"
          ].map(item => (
            <li style="display: flex; align-items: center; gap: 0.75rem; padding: 0.75rem 0; border-bottom: 1px solid var(--color-border);">
              <span style="color: var(--color-copper);">✓</span>
              <span style="color: var(--color-text-secondary);">{item}</span>
            </li>
          ))}
        </ul>
        
        <a href="/product" class="btn btn-primary" style="width: 100%; max-width: 300px;">Get the Pack — $19</a>
      </div>
    </section>

    <!-- FAQ -->
    <section style="padding: 6rem 0;">
      <div class="container" style="max-width: 700px;">
        <div style="text-align: center; margin-bottom: 3rem;">
          <h2>Frequently Asked</h2>
        </div>
        
        <div style="display: flex; flex-direction: column; gap: 1rem;">
          {[
            { q: "What's actually included?", a: "You get 25 AI prompts organized into 5 categories plus 10 professional email templates. Everything is delivered as both PDF and Markdown files for immediate use." },
            { q: "Do I need technical skills?", a: "Not at all. If you can copy and paste, you can use these prompts. Simply copy the template, fill in your details, and paste into any AI tool." },
            { q: "How do I receive the product?", a: "Instant download after purchase. You'll get a ZIP file with both PDF and Markdown versions. No waiting, no login portals." },
            { q: "What if I'm not satisfied?", a: "30-day money-back guarantee. Email support@thezeromethod.com within 30 days for a full refund. No forms, no questions asked." }
          ].map(faq => (
            <details style="background: var(--color-bg-secondary); border-radius: var(--radius-md); overflow: hidden;">
              <summary style="padding: 1.25rem; cursor: pointer; font-weight: 500; display: flex; justify-content: space-between; align-items: center;">
                {faq.q}
                <span style="color: var(--color-copper);">+</span>
              </summary>
              <div style="padding: 0 1.25rem 1.25rem; color: var(--color-text-secondary); line-height: 1.7;">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section style="padding: 6rem 0; background: var(--color-bg-secondary);">
      <div class="container" style="text-align: center;">
        <h2 style="margin-bottom: 1rem;">Stop writing prompts from scratch.</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 2rem; max-width: 500px; margin-left: auto; margin-right: auto;">
          Get 25 proven prompts and 10 templates. Start saving time today.
        </p>
        
        <a href="/product" class="btn btn-primary">Get the Pack — $19</a>
        
        <p style="margin-top: 1.5rem; font-size: 0.875rem; color: var(--color-text-muted);">
          30-day money-back guarantee • Instant download
        </p>
      </div>
    </section>
  </main>
  
  <Footer />
</Layout>