---
const posts = [
  {
    title: "AI Market This Week: What Actually Matters",
    slug: "ai-market-week-1",
    category: "Analysis",
    readTime: "5 min",
    excerpt: "The signal in the noise — what professionals should actually pay attention to this week."
  },
  {
    title: "The 5-Minute Email That Actually Works",
    slug: "the-5-minute-email",
    category: "Email",
    readTime: "4 min",
    excerpt: "A prompt we tested 47 times before including it in the pack."
  },
  {
    title: "Welcome to Zero Method",
    slug: "welcome-to-zero-method",
    category: "Welcome",
    readTime: "3 min",
    excerpt: "Why we built this and what makes us different."
  }
];
---

<section class="min-h-screen pt-32 pb-20 px-6">
  <div class="max-w-4xl mx-auto">
    <div class="text-center mb-12">
      <p class="text-sm font-medium text-amber-400 mb-4">Blog</p>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight gradient-text">Zero Method Blog</h1>
      <p class="text-gray-400 mt-4">Tips, insights, and strategies for using AI to boost productivity.</p>
    </div>

    <div class="space-y-6">
      {posts.map(post => (
        <a href={`/blog/${post.slug}`} class="card block hover:border-amber-500/30 transition-colors">
          <div class="flex flex-col md:flex-row md:items-center gap-4">
            <div class="flex items-center gap-3">
              <span class="px-3 py-1 rounded-full bg-white/5 text-xs text-amber-400">{post.category}</span>
              <span class="text-xs text-gray-500">{post.readTime}</span>
            </div>
            <div class="flex-1">
              <h2 class="text-xl font-semibold mb-2 hover:text-amber-400 transition-colors">{post.title}</h2>
              <p class="text-gray-400 text-sm">{post.excerpt}</p>
            </div>
            <span class="text-amber-400">→</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>