---
const posts = [
  {
    title: "AI Market This Week: What Actually Matters",
    slug: "ai-market-week-1",
    category: "Analysis",
    readTime: "5 min",
    excerpt: "The signal in the noise — what professionals should actually pay attention to this week."
  },
  {
    title: "The 5-Minute Email That Actually Works",
    slug: "the-5-minute-email",
    category: "Email",
    readTime: "4 min",
    excerpt: "A prompt we tested 47 times before including it in the pack."
  },
  {
    title: "Welcome to Zero Method",
    slug: "welcome-to-zero-method",
    category: "Welcome",
    readTime: "3 min",
    excerpt: "Why we built this and what makes us different."
  }
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog | Zero Method</title>
  <meta name="description" content="Tips, insights, and strategies for using AI to boost productivity." />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --obsidian: #0A0A0F;
      --void: #141418;
      --gold: #F59E0B;
      --amber: #FBBF24;
      --white: #FFFFFF;
      --smoke: #A1A1AA;
      --slate: #71717A;
      --ink: #27272A;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    body {
      font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
      background: var(--obsidian);
      color: var(--white);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
    }
    .btn-primary {
      background: linear-gradient(135deg, var(--amber), var(--gold));
      color: #000;
      font-weight: 600;
      padding: 12px 24px;
      border-radius: 9999px;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: 8px;
      transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
      border: none;
      cursor: pointer;
      font-size: 14px;
    }
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 10px 30px -10px rgba(245, 158, 11, 0.4);
    }
  </style>
</head>
<body>
  <!-- Navigation -->
  <nav style="position: fixed; top: 0; left: 0; right: 0; z-index: 50; background: rgba(10,10,15,0.9); backdrop-filter: blur(20px); border-bottom: 1px solid rgba(255,255,255,0.05);">
    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; height: 64px; display: flex; align-items: center; justify-content: space-between;">
      <a href="/" style="display: flex; align-items: center; gap: 10px; text-decoration: none;">
        <div style="width: 32px; height: 32px; background: white; border-radius: 8px; display: flex; align-items: center; justify-content: center;">
          <span style="color: black; font-weight: bold; font-size: 14px;">0</span>
        </div>
        <span style="font-weight: 600; color: white;">Zero Method</span>
      </a>
      
      <div style="display: flex; align-items: center; gap: 24px;">
        <a href="/" style="color: #A1A1AA; text-decoration: none; font-size: 14px; display: flex; align-items: center; gap: 6px;">
          <span>←</span> Back to Home
        </a>
        <a href="/product" class="btn-primary" style="font-size: 14px; padding: 10px 20px;">Get Started</a>
      </div>
    </div>
  </nav>

  <!-- Blog Content -->
  <section style="min-height: 100vh; padding: 128px 24px 80px;">
    <div style="max-width: 800px; margin: 0 auto; text-align: center;">
      <p style="font-size: 14px; font-weight: 500; color: #F59E0B; margin-bottom: 16px;">Blog</p>
      <h1 style="font-size: 40px; font-weight: 700; margin-bottom: 16px; color: white;">Zero Method Blog</h1>
      <p style="color: #A1A1AA; margin-bottom: 48px;">Tips, insights, and strategies for using AI to boost productivity.</p>

      <div style="display: flex; flex-direction: column; gap: 16px;">
        {posts.map(post => (
          <a href={`/blog/${post.slug}`} 
             style="background: rgba(255,255,255,0.02); border: 1px solid rgba(255,255,255,0.06); border-radius: 16px; padding: 24px; text-decoration: none; color: inherit; display: flex; align-items: center; gap: 24px; transition: all 0.3s ease; text-align: left;"
             onmouseover="this.style.background='rgba(255,255,255,0.04)'; this.style.borderColor='rgba(255,255,255,0.12)'; this.style.transform='translateY(-2px)';"
             onmouseout="this.style.background='rgba(255,255,255,0.02)'; this.style.borderColor='rgba(255,255,255,0.06)'; this.style.transform='translateY(0)';"
          >
            <div style="display: flex; align-items: center; gap: 12px; min-width: 140px;">
              <span style="padding: 4px 12px; background: rgba(245,158,11,0.1); border-radius: 9999px; font-size: 12px; color: #F59E0B;">{post.category}</span>
              <span style="font-size: 12px; color: #71717A;">{post.readTime}</span>
            </div>
            
            <div style="flex: 1;">
              <div style="font-size: 18px; font-weight: 600; color: white; margin-bottom: 4px;">{post.title}</div>
              <div style="color: #A1A1AA; font-size: 14px;">{post.excerpt}</div>
            </div>
            <span style="color: #F59E0B; font-size: 20px;">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</body>
</html>