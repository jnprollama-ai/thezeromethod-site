---
import AiToolsWeUse from './ai-tools-we-use.astro';
import ThePrompt from './the-prompt-that-changed-everything.astro';
import BlogPost30Min from './30-minute-blog-post.astro';
import EmailSystem from './5-minute-email-system.astro';
import AiMarketWeek from './ai-market-week-1.astro';
import AiAutomationWorkflow from './ai-automation-workflow-guide.astro';
import ApiIntegration from './api-integration-automation-guide.astro';
import EmailTemplates from './15-email-templates-that-get-responses.astro';
import AiProductivityStack from './ai-productivity-stack-april-2026.astro';
import AiForecast from './ai-productivity-forecast-2026.astro';
import AiGap from './ai-productivity-gap-2026.astro';
import SuccessStories from './success-stories-april-2026.astro';

export async function getStaticPaths() {
  const posts = [
    { slug: 'ai-tools-we-use', component: AiToolsWeUse },
    { slug: 'the-prompt-that-changed-everything', component: ThePrompt },
    { slug: '30-minute-blog-post', component: BlogPost30Min },
    { slug: '5-minute-email-system', component: EmailSystem },
    { slug: 'ai-market-week-1', component: AiMarketWeek },
    { slug: 'ai-automation-workflow-guide', component: AiAutomationWorkflow },
    { slug: 'api-integration-automation-guide', component: ApiIntegration },
    { slug: '15-email-templates-that-get-responses', component: EmailTemplates },
    { slug: 'ai-productivity-stack-april-2026', component: AiProductivityStack },
    { slug: 'ai-productivity-forecast-2026', component: AiForecast },
    { slug: 'ai-productivity-gap-2026', component: AiGap },
    { slug: 'success-stories-april-2026', component: SuccessStories }
  ];
  return posts.map(post => ({ params: { slug: post.slug }, props: { component: post.component } }));
}

const { slug } = Astro.params;
const { component: PostComponent } = Astro.props;
---

{PostComponent ? <PostComponent /> : (
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog Post | Zero Method</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: 'Inter', sans-serif; background: #0A0A0F; color: #fff; line-height: 1.7; min-height: 100vh; }
    nav { background: rgba(10,10,15,0.9); padding: 1rem 2rem; position: fixed; width: 100%; top: 0; backdrop-filter: blur(10px); border-bottom: 1px solid #27272A; z-index: 100; }
    .container { max-width: 800px; margin: 0 auto; padding: 100px 2rem 4rem; }
    h1 { font-size: 2.5rem; margin-bottom: 1rem; text-align: center; }
    .loading { text-align: center; padding: 4rem 2rem; }
    .loading p { color: #A1A1AA; font-size: 1.2rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/" style="color: #F59E0B; text-decoration: none; font-weight: 700; font-size: 1.25rem;">Zero<span style="color: #fff;">Method</span></a>
  </nav>
  <div class="container">
    <div class="loading">
      <h1>Loading...</h1>
      <p>Fetching blog content for: {slug}</p>
    </div>
  </div>
</body>
</html>
)}