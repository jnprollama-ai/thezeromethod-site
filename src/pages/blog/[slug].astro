---
export async function getStaticPaths() {
  const posts = [
    { slug: 'ai-tools-we-use' },
    { slug: 'the-prompt-that-changed-everything' },
    { slug: '30-minute-blog-post' },
    { slug: '5-minute-email-system' },
    { slug: 'ai-market-week-1' },
    { slug: 'ai-automation-workflow-guide' },
    { slug: 'api-integration-automation-guide' },
    { slug: '15-email-templates-that-get-responses' },
    { slug: 'ai-productivity-stack-april-2026' },
    { slug: 'ai-productivity-forecast-2026' },
    { slug: 'ai-productivity-gap-2026' },
    { slug: 'success-stories-april-2026' }
  ];
  return posts.map(post => ({ params: post }));
}

const { slug } = Astro.params;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Blog Post | Zero Method</title>
  <meta name="description" content="AI productivity tips and strategies." />
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { font-family: Inter, sans-serif; background: #0A0A0F; color: #fff; line-height: 1.7; }
    nav { background: rgba(10,10,15,0.9); padding: 1rem 2rem; position: fixed; width: 100%; top: 0; backdrop-filter: blur(10px); border-bottom: 1px solid #27272A; }
    .container { max-width: 800px; margin: 0 auto; padding: 100px 2rem 4rem; }
    h1 { font-size: 2.5rem; margin-bottom: 1rem; }
    p { color: #A1A1AA; margin-bottom: 1rem; }
    .btn { background: linear-gradient(135deg, #FBBF24, #F59E0B); color: #000; padding: 12px 24px; border-radius: 9999px; text-decoration: none; display: inline-block; margin-top: 2rem; font-weight: 600; }
    .meta { color: #71717A; margin-bottom: 2rem; }
    .content { background: rgba(255,255,255,0.03); border: 1px solid rgba(255,255,255,0.1); border-radius: 12px; padding: 2rem; }
  </style>
</head>
<body>
  <nav>
    <a href="/" style="color: #F59E0B; text-decoration: none; font-weight: 700; font-size: 1.25rem;">Zero<span style="color: #fff;">Method</span></a>
  </nav>
  <div class="container">
    <h1>Post: {slug}</h1>
    <p class="meta">Loading content...</p>
    <div class="content">
      <p>This blog post is being generated. Check back soon for the full content.</p>
      <p style="margin-top: 1rem;"><strong>Slug:</strong> {slug}</p>
    </div>
    <a href="/blog" class="btn">← Back to Blog</a>
  </div>
</body>
</html>
