---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';
import StripeButton from '@components/StripeButton.astro';

const title = "Product | Zero Method - AI Prompts Starter Pack";
const description = "25 battle-tested AI prompts + 10 professional email templates. Save hours every week with copy-paste ready prompts for ChatGPT and Claude.";
const keywords = "AI prompts, email templates, ChatGPT prompts, Claude prompts, productivity, automation, AI tools";

const features = [
  {
    icon: "🚀",
    title: "25 Battle-Tested Prompts",
    description: "25 carefully crafted prompts across 5 categories: Email, Reports, Content, Productivity, and Research. Each tested for consistent results."
  },
  {
    icon: "📄",
    title: "10 Email Templates",
    description: "Professional email templates for cold outreach, follow-ups, meeting requests, declining politely, and relationship maintenance."
  },
  {
    icon: "📖",
    title: "PDF + Markdown Formats",
    description: "Download as a clean PDF for offline access, or use the markdown version. Copy-paste ready for immediate use."
  },
  {
    icon: "🔄",
    title: "Free Updates for 1 Year",
    description: "Get all updates and additions for a full year after purchase. As we expand the library, you get the new content."
  },
  {
    icon: "⚡",
    title: "Immediate Download",
    description: "No waiting. Get instant access to everything right after purchase. Start saving time in the next 5 minutes."
  },
  {
    icon: "💯",
    title: "30-Day Guarantee",
    description: "Not satisfied? Email us within 30 days for a full refund. No questions asked. We only want happy customers."
  }
];

const tiers = [
  {
    name: "Starter Pack",
    price: "$19",
    priceId: "price_1THh7pB0SuyNKPsMn02w3pva", // Zero Method Starter Pack
    tier: "starter",
    description: "Perfect for individuals getting started with AI productivity",
    features: [
      "25 AI Prompts (5 categories)",
      "10 Email Templates",
      "PDF + Markdown formats",
      "Usage instructions",
      "Email Support",
      "1 year of updates"
    ],
    cta: "Buy Now",
    popular: true,
    status: "Available Now"
  }
];

const faqs = [
  {
    question: "What's actually included?",
    answer: "You get 25 AI prompts organized into 5 categories (Email, Reports, Content, Productivity, Research) plus 10 professional email templates. Everything is delivered as both PDF and Markdown files for immediate use. No videos, no worksheets, no community—just solid, tested prompts that work."
  },
  {
    question: "Do I need technical skills?",
    answer: "Not at all. If you can copy and paste, you can use these prompts. Simply copy the prompt template, fill in your specific details where indicated, and paste into ChatGPT, Claude, or any AI tool. Each prompt includes clear instructions on how to customize it."
  },
  {
    question: "How will I receive the product?",
    answer: "Immediate download after purchase. You'll get a ZIP file containing the PDF version and Markdown version. Extract and start using right away. No login portals, no waiting, no complexity."
  },
  {
    question: "What format is the product in?",
    answer: "PDF (for easy reading and offline access) and Markdown (for easy copying and editing). The PDF is professionally formatted and printable. The Markdown files work in any text editor or note-taking app."
  },
  {
    question: "Are there video tutorials?",
    answer: "No. We don't offer video tutorials at this time. Each prompt includes written usage instructions. If you're looking for video content, this product may not be for you. We're focused on written, copy-paste-ready resources."
  },
  {
    question: "What if I'm not satisfied?",
    answer: "30-day money-back guarantee. If these prompts don't save you time, email us at support@thezeromethod.com within 30 days for a full refund. No questions asked, no hoops to jump through."
  },
  {
    question: "Will there be updates?",
    answer: "Yes. When you buy, you get free updates for 1 year. As we add new prompts and templates, you'll receive an email with the download link for the updated version. No re-purchasing, no additional fees."
  },
  {
    question: "Can I use this for my clients?",
    answer: "The Starter Pack is for personal use. You can use the prompts and templates for your own work, but please don't resell or redistribute them. If you need commercial rights for client work, contact us about upcoming licensing options."
  }
];

const whatsIncluded = [
  { name: "25 AI Prompts Collection", desc: "Email, Reports, Content, Productivity, Research" },
  { name: "10 Email Templates", desc: "Cold outreach, follow-ups, professional communication" },
  { name: "PDF Version", desc: "Formatted and printable" },
  { name: "Markdown Version", desc: "Editable and copy-paste ready" },
  { name: "Usage Instructions", desc: "How to customize each prompt" },
  { name: "1 Year of Updates", desc: "New content as we add it" }
];
---

<Layout title={title} description={description} keywords={keywords}>
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="relative pt-32 pb-20 lg:pt-40 lg:pb-32">
      <div class="absolute inset-0 bg-gradient-to-b from-navy-900/50 via-navy-950 to-navy-950"></div>

      <div class="relative max-w-7xl mx-auto px-6 lg:px-8">
        <div class="text-center max-w-4xl mx-auto">
          <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
            25 AI Prompts That <span class="bg-gradient-to-r from-gold-400 to-gold-600 bg-clip-text text-transparent">Save 5 Hours Every Week</span>
          </h1>
          <p class="text-lg sm:text-xl text-navy-300 mb-10 max-w-2xl mx-auto leading-relaxed">
            Copy-paste ready prompts for ChatGPT and Claude. No fluff, no videos, just battle-tested templates that work.
          </p>
          <a
            href="#pricing"
            class="inline-flex items-center px-8 py-4 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold text-lg rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-gold-500/20"
          >
            Get the Pack — $19
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
            </svg>
          </a>
          <p class="mt-4 text-navy-400 text-sm">30-day money-back guarantee • Instant download</p>
        </div>
      </div>
    </section>

    <!-- Features Grid -->
    <section class="py-20 bg-navy-900/50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            What's Included
          </h2>
          <p class="text-navy-400 text-lg">
            Everything you need, nothing you don't. Just tested prompts that save time.
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {features.map(feature => (
            <div class="p-8 bg-navy-900 rounded-2xl border border-navy-800 hover:border-gold-500/30 transition-colors duration-300">
              <div class="text-4xl mb-4">{feature.icon}</div>
              <h3 class="text-xl font-semibold text-white mb-3">{feature.title}</h3>
              <p class="text-navy-400 leading-relaxed">{feature.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- What's Included -->
    <section class="py-20">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
          <div>
            <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
              The Complete Package
            </h2>
            <p class="text-navy-400 text-lg mb-8 leading-relaxed">
              25 carefully crafted prompts across 5 essential categories, plus 10 professional email templates. 
              Everything is copy-paste ready and includes clear instructions.
            </p>
            <div class="space-y-4">
              {whatsIncluded.map(item => (
                <div class="flex items-start space-x-4">
                  <div class="flex-shrink-0 w-6 h-6 rounded-full bg-gold-500/20 flex items-center justify-center">
                    <svg class="w-4 h-4 text-gold-500" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-white font-medium">{item.name}</h4>
                    <p class="text-navy-400 text-sm">{item.desc}</p>
                  </div>
                </div>
              ))}
            </div>
          </div>

          <div class="relative">
            <div class="absolute inset-0 bg-gradient-to-br from-gold-500/20 to-transparent rounded-2xl"></div>
            <div class="relative bg-navy-900 rounded-2xl p-8 border border-navy-800">
              <div class="space-y-6">
                <div class="flex items-center space-x-4">
                  <div class="w-12 h-12 rounded-lg bg-gold-500/20 flex items-center justify-center">
                    <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-white font-medium">PDF Format</h4>
                    <p class="text-navy-400 text-sm">Clean, printable, offline access</p>
                  </div>
                </div>
                <div class="flex items-center space-x-4">
                  <div class="w-12 h-12 rounded-lg bg-gold-500/20 flex items-center justify-center">
                    <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-white font-medium">Markdown Format</h4>
                    <p class="text-navy-400 text-sm">Easy to edit and customize</p>
                  </div>
                </div>
                <div class="flex items-center space-x-4">
                  <div class="w-12 h-12 rounded-lg bg-gold-500/20 flex items-center justify-center">
                    <svg class="w-6 h-6 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                    </svg>
                  </div>
                  <div>
                    <h4 class="text-white font-medium">ZIP Download</h4>
                    <p class="text-navy-400 text-sm">Both formats in one file</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Pricing -->
    <section id="pricing" class="py-20 bg-navy-900/50">
      <div class="max-w-7xl mx-auto px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="text-3xl sm:text-4xl font-bold text-white mb-4">
            Simple Pricing
          </h2>
          <p class="text-navy-400 text-lg">
            One product, one price. No tiers, no subscriptions, no surprises.
          </p>
        </div>

        <div class="max-w-lg mx-auto">
          {tiers.map(tier => (
            <div class={`relative p-8 rounded-2xl border-2 ${
              tier.popular 
                ? 'border-gold-500 bg-navy-900' 
                : 'border-navy-800 bg-navy-900/50'
            }`}>
              {tier.popular && (
                <div class="absolute -top-4 left-1/2 transform -translate-x-1/2">
                  <span class="bg-gold-500 text-navy-900 px-4 py-1 rounded-full text-sm font-bold">
                    Available Now
                  </span>
                </div>
              )}
              
              <div class="text-center mb-8">
                <h3 class="text-2xl font-bold text-white mb-2">{tier.name}</h3>
                <p class="text-navy-400 mb-4">{tier.description}</p>
                <div class="flex items-baseline justify-center">
                  <span class="text-5xl font-bold text-white">{tier.price}</span>
                  <span class="text-navy-400 ml-2">one-time</span>
                </div>
              </div>

              <ul class="space-y-4 mb-8">
                {tier.features.map(feature => (
                  <li class="flex items-start space-x-3">
                    <svg class="w-5 h-5 text-gold-500 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
                    </svg>
                    <span class="text-navy-300">{feature}</span>
                  </li>
                ))}
              </ul>

              <button
                class={`w-full py-4 px-6 rounded-lg font-bold text-lg transition-all duration-200 ${
                  tier.popular
                    ? 'bg-gold-500 hover:bg-gold-600 text-navy-900'
                    : 'bg-navy-800 hover:bg-navy-700 text-white border border-navy-700'
                }`}
              >
                {tier.cta}
              </button>

              <p class="text-center text-navy-400 text-sm mt-4">
                {tier.status === 'Available Now' 
                  ? 'Instant download after purchase' 
                  : 'Join waitlist for updates'}
              </p>
            </div>
          ))}
        </div>

        <div class="max-w-2xl mx-auto mt-12 text-center">
          <p class="text-navy-400 text-sm">
            🔒 Secure payment via Stripe • 📧 Delivery via email • 💯 30-day guarantee
          </p>
        </div>
      </div>
    </section>

    <!-- FAQ Section -->
    <section class="py-20">
      <div class="max-w-4xl mx-auto px-6 lg:px-8">
        <h2 class="text-3xl sm:text-4xl font-bold text-white text-center mb-12">
          Frequently Asked Questions
        </h2>
        <div class="space-y-6">
          {faqs.map(faq => (
            <div class="bg-navy-900 rounded-xl p-6 border border-navy-800">
              <h3 class="text-lg font-semibold text-white mb-3">{faq.question}</h3>
              <p class="text-navy-400 leading-relaxed">{faq.answer}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Final CTA -->
    <section class="py-20 bg-navy-900/50">
      <div class="max-w-3xl mx-auto px-6 lg:px-8 text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-white mb-6">
          Ready to Save 5 Hours This Week?
        </h2>
        <p class="text-navy-400 text-lg mb-8">
          Get 25 proven prompts and 10 email templates. Copy, paste, and start saving time today.
        </p>
        <a
          href="#pricing"
          class="inline-flex items-center px-8 py-4 bg-gold-500 hover:bg-gold-600 text-navy-900 font-bold text-lg rounded-lg transition-all duration-200 hover:shadow-lg hover:shadow-gold-500/20"
        >
          Get Started — $19
        </a>
        <p class="mt-4 text-navy-400 text-sm">
          30-day money-back guarantee
        </p>
      </div>
    </section>
  </main>

  <Footer />
</Layout>
