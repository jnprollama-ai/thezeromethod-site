---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Zero Method Starter Pack — 25 AI Prompts + 10 Templates";
const description = "Get 25 battle-tested AI prompts + 10 email templates for $19. One-time purchase. 30-day guarantee.";
---

<Layout title={title} description={description}>
  <Header />
  
  <main class="pt-32 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumb -->
      <div class="text-sm text-gray-400 mb-8">
        <a href="/" class="hover:text-white">Home</a> → Starter Pack
      </div>

      <!-- Product Hero -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20">
        <div>
          <p class="text-sm font-medium text-amber-400 mb-4">Starter Pack</p>
          
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight mb-6">
            <span class="gradient-text">The Zero Method</span><br>
            <span class="gradient-gold">Starter Pack</span>
          </h1>
          
          <p class="text-xl text-gray-400 mb-8">
            25 prompts + 10 templates. $19 one-time. Instant download.
          </p>
          
          <div class="flex items-baseline gap-4 mb-8">
            <span class="text-5xl font-bold">$19</span>
            <span class="text-gray-400">one-time</span>
          </div>
          
          <div class="space-y-4 mb-8">
            <button class="btn-primary w-full max-w-md justify-center text-lg">
              Pay with Card — $19
            </button>
            
            <div class="flex items-center gap-6 text-sm text-gray-400 max-w-md">
              <span>🔒 SSL Secured</span>
              <span>✓ 30-Day Guarantee</span>
              <span>⚡ Instant Download</span>
            </div>
          </div>
        </div>
        
        <div class="card p-8 flex items-center justify-center">
          <div class="text-center">
            <div class="text-6xl font-bold gradient-gold mb-2">ZERO</div>
            <div class="text-xl text-gray-400 tracking-widest">METHOD</div>
            <div class="mt-4 text-sm text-gray-500">Starter Pack</div>
          </div>
        </div>
      </div>

      <!-- What's Included -->
      <div class="mb-20">
        <h2 class="text-3xl font-bold mb-8 gradient-text">What You Get</h2>
        
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <h3 class="text-lg font-semibold mb-3 text-amber-400">25 AI Prompts</h3>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li>✓ Email & Communication (5)</li>
              <li>✓ Reports & Documentation (5)</li>
              <li>✓ Content Creation (5)</li>
              <li>✓ Productivity & Organization (5)</li>
              <li>✓ Research & Analysis (5)</li>
            </ul>
          </div>
          
          <div>
            <h3 class="text-lg font-semibold mb-3 text-amber-400">10 Email Templates</h3>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li>✓ Cold outreach (2)</li>
              <li>✓ Follow-up sequences (3)</li>
              <li>✓ Status updates (2)</li>
              <li>✓ Meeting requests (2)</li>
              <li>✓ Thank you / close (1)</li>
            </ul>
          </div>
          
          <div>
            <h3 class="text-lg font-semibold mb-3 text-amber-400">Included Free</h3>
            <ul class="space-y-2 text-gray-400 text-sm">
              <li>✓ Markdown source files</li>
              <li>✓ Organized by category</li>
              <li>✓ 1 year of updates</li>
              <li>✓ 30-day money-back guarantee</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Guarantee -->
      <div class="bg-[#141418] rounded-2xl p-8 text-center">
        <h2 class="text-2xl font-bold mb-4">30-Day No-Questions-Asked Refund</h2>
        <p class="text-gray-400 mb-6 max-w-2xl mx-auto">
          If you open the pack and it doesn't save you time in the first 30 days, email support@thezeromethod.com. You'll get a full refund within 24 hours. No forms. No explanations required.
        </p>
        
        <button class="btn-primary text-lg">
          Get the Pack — $19
        </button>
      </div>
    </div>
  </main>

  <Footer />
</Layout>