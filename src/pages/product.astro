---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Products | Zero Method - AI Tools & Guides";
const description = "Choose your toolkit. From AI prompts to complete installation guides, get the resources you need to work smarter.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-6">
      <!-- Hero -->
      <div class="text-center mb-16">
        <h1 class="text-4xl md:text-5xl font-bold mb-4">
          Choose Your <span class="text-amber-400">Toolkit</span>
        </h1>
        <p class="text-gray-400 text-lg max-w-2xl mx-auto">
          From AI prompts to complete installation guides. Get the resources you need to work smarter, not harder.
        </p>
        
        <!-- Trust Badges -->
        <div class="flex flex-wrap justify-center gap-6 mt-6 text-sm text-gray-400">
          <span class="flex items-center gap-1"><span class="text-amber-400">✓</span> 1500+ Customers</span>
          <span class="flex items-center gap-1"><span class="text-amber-400">★</span> 4.9/5 Rating</span>
          <span class="flex items-center gap-1"><span class="text-amber-400">✓</span> 30-Day Guarantee</span>
        </div>
      </div>

      <!-- Product Tabs -->
      <div class="flex flex-wrap justify-center gap-4 mb-12">
        <a href="#productivity" class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-lg transition-colors">🤖 AI Productivity Suite</a>
        <a href="#openclaw" class="px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-lg transition-colors">🦞 OpenClaw Installation Guide</a>
        <a href="#bundle" class="px-6 py-3 bg-amber-500 hover:bg-amber-600 text-black font-bold rounded-lg transition-colors">💰 Bundle & Save 30%</a>
      </div>

      <!-- Product 1: AI Productivity Suite -->
      <section id="productivity" class="mb-20 pb-20 border-b border-gray-800">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-amber-500/10 text-amber-400 rounded-full text-sm font-medium mb-4">⭐ Most Popular</span>
          <h2 class="text-3xl font-bold mb-2">AI Productivity Suite</h2>
          <p class="text-gray-400">150+ battle-tested prompts and templates that save you 10+ hours every week.</p>
        </div>

        <!-- Features -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="card p-6">
            <div class="text-3xl mb-3">🚀</div>
            <h3 class="font-semibold mb-2">150+ Battle-Tested Prompts</h3>
            <p class="text-gray-400 text-sm">Copy-paste ready prompts for ChatGPT, Claude, and Gemini.</p>
          </div>
          <div class="card p-6">
            <div class="text-3xl mb-3">📄</div>
            <h3 class="font-semibold mb-2">40+ Done-For-You Templates</h3>
            <p class="text-gray-400 text-sm">Professionally designed templates for emails, content, analysis.</p>
          </div>
          <div class="card p-6">
            <div class="text-3xl mb-3">🎥</div>
            <h3 class="font-semibold mb-2">Video Walkthroughs</h3>
            <p class="text-gray-400 text-sm">Step-by-step video guides showing exactly how to use each prompt.</p>
          </div>
        </div>

        <!-- Pricing -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Essential -->
          <div class="card p-6 border border-gray-700">
            <h3 class="text-xl font-bold mb-2">Essential</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold">$49</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">Perfect for individuals getting started</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> 50+ Core Prompts</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> 15 Email Templates</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Basic Video Tutorials</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> PDF Worksheets</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Email Support</li>
            </ul>
            <button class="w-full py-3 bg-gray-700 hover:bg-gray-600 rounded-lg font-medium transition-colors">Get Essential</button>
          </div>

          <!-- Professional -->
          <div class="card p-6 border-2 border-amber-500 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="px-3 py-1 bg-amber-500 text-black text-sm font-bold rounded-full">Most Popular</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Professional</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold text-amber-400">$79</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">For serious professionals</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> 150+ Premium Prompts</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> 40+ Templates</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Full Video Course (10+ hrs)</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Interactive Worksheets</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Priority Support</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Community Access</li>
            </ul>
            <button class="w-full py-3 bg-amber-500 hover:bg-amber-600 text-black rounded-lg font-bold transition-colors">Get Professional</button>
          </div>

          <!-- Agency -->
          <div class="card p-6 border border-gray-700">
            <h3 class="text-xl font-bold mb-2">Agency</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold">$149</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">For teams and agencies</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Everything in Professional</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Agency License (5 seats)</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> White-Label Templates</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> API Access</li>
              <li class="flex items-center gap-2"><span class="text-amber-400">✓</span> Dedicated Support</li>
            </ul>
            <button class="w-full py-3 bg-gray-700 hover:bg-gray-600 rounded-lg font-medium transition-colors">Get Agency</button>
          </div>
        </div>
      </section>

      <!-- Product 2: OpenClaw Installation Guide -->
      <section id="openclaw" class="mb-20 pb-20 border-b border-gray-800">
        <div class="text-center mb-12">
          <span class="inline-block px-3 py-1 bg-blue-500/10 text-blue-400 rounded-full text-sm font-medium mb-4">🆕 New Release</span>
          <h2 class="text-3xl font-bold mb-2">OpenClaw Installation Mastery</h2>
          <p class="text-gray-400">The complete guide to installing OpenClaw on any platform. 7 methods, security hardening, troubleshooting.</p>
        </div>

        <!-- Features -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
          <div class="card p-6">
            <div class="text-3xl mb-3">📚</div>
            <h3 class="font-semibold mb-2">7 Installation Methods</h3>
            <p class="text-gray-400 text-sm">GUI, npm, Homebrew, Docker, cloud VPS — every method covered.</p>
          </div>
          <div class="card p-6">
            <div class="text-3xl mb-3">🔧</div>
            <h3 class="font-semibold mb-2">Step-by-Step Commands</h3>
            <p class="text-gray-400 text-sm">Copy-paste ready commands for each platform.</p>
          </div>
          <div class="card p-6">
            <div class="text-3xl mb-3">🛡️</div>
            <h3 class="font-semibold mb-2">Security Hardening</h3>
            <p class="text-gray-400 text-sm">Production deployment checklist and reverse proxy configs.</p>
          </div>
        </div>

        <!-- Pricing -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Standard -->
          <div class="card p-6 border border-gray-700">
            <h3 class="text-xl font-bold mb-2">Standard</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold">$29</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">Complete guide for personal use</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> PDF Guide (60+ pages)</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Windows, Mac, Linux</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Docker Deployment</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> API Configuration</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Basic Troubleshooting</li>
            </ul>
            <button class="w-full py-3 bg-gray-700 hover:bg-gray-600 rounded-lg font-medium transition-colors">Get Guide</button>
          </div>

          <!-- Professional -->
          <div class="card p-6 border-2 border-blue-500 relative">
            <div class="absolute -top-3 left-1/2 -translate-x-1/2">
              <span class="px-3 py-1 bg-blue-500 text-white text-sm font-bold rounded-full">Best Value</span>
            </div>
            <h3 class="text-xl font-bold mb-2">Professional</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold text-blue-400">$49</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">Cloud deployment + security</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Everything in Standard</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Cloud VPS (AWS, DO)</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Security Hardening</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Nginx/Caddy Configs</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Priority Email Support</li>
            </ul>
            <button class="w-full py-3 bg-blue-500 hover:bg-blue-600 text-white rounded-lg font-bold transition-colors">Get Pro Guide</button>
          </div>

          <!-- Enterprise -->
          <div class="card p-6 border border-gray-700">
            <h3 class="text-xl font-bold mb-2">Enterprise</h3>
            <div class="flex items-baseline gap-2 mb-2">
              <span class="text-3xl font-bold">$99</span>
              <span class="text-gray-400 text-sm">one-time</span>
            </div>
            <p class="text-gray-400 text-sm mb-4">Team license with automation</p>
            <ul class="space-y-2 text-sm text-gray-300 mb-6">
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Everything in Pro</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Team License (10 users)</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> CI/CD Scripts</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Terraform Templates</li>
              <li class="flex items-center gap-2"><span class="text-blue-400">✓</span> Priority Support</li>
            </ul>
            <button class="w-full py-3 bg-gray-700 hover:bg-gray-600 rounded-lg font-medium transition-colors">Get Enterprise</button>
          </div>
        </div>
      </section>

      <!-- Bundle Offer -->
      <section id="bundle" class="mb-20">
        <div class="card p-8 lg:p-12 bg-gradient-to-br from-amber-500/10 to-gray-900 border-amber-500/20">
          <div class="text-center mb-8">
            <span class="inline-block px-3 py-1 bg-amber-500 text-black text-sm font-bold rounded-full mb-4">💰 Save 30%</span>
            <h2 class="text-3xl font-bold mb-2">Complete AI Toolkit</h2>
            <p class="text-gray-400">Get both products and save $39. Everything you need to master AI productivity.</p>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
            <div class="card p-6">
              <div class="text-4xl mb-3">🤖</div>
              <h3 class="font-bold mb-1">AI Productivity Suite</h3>
              <p class="text-gray-400 text-sm">150+ prompts, 40+ templates, video course</p>
            </div>
            <div class="card p-6">
              <div class="text-4xl mb-3">🦞</div>
              <h3 class="font-bold mb-1">OpenClaw Installation Guide</h3>
              <p class="text-gray-400 text-sm">7 methods, security hardening, cloud deployment</p>
            </div>
          </div>

          <div class="text-center">
            <div class="flex items-center justify-center gap-4 mb-6">
              <span class="text-gray-500 line-through text-xl">$128</span>
              <span class="text-5xl font-bold text-amber-400">$89</span>
              <span class="text-gray-400">one-time</span>
            </div>

            <ul class="space-y-2 mb-6 text-gray-300">
              <li class="flex items-center justify-center gap-2"><span class="text-amber-400">✓</span> AI Productivity Suite (Professional)</li>
              <li class="flex items-center justify-center gap-2"><span class="text-amber-400">✓</span> OpenClaw Installation Guide (Professional)</li>
              <li class="flex items-center justify-center gap-2"><span class="text-amber-400">✓</span> Bonus: API Configuration Cheatsheet</li>
              <li class="flex items-center justify-center gap-2"><span class="text-amber-400">✓</span> Bonus: 20 Advanced Prompts</li>
            </ul>

            <button class="px-8 py-4 bg-amber-500 hover:bg-amber-600 text-black font-bold rounded-xl text-lg transition-colors">
              Get Complete Toolkit — $89
            </button>
            <p class="text-gray-500 text-sm mt-4">30-day money-back guarantee • Instant download</p>
          </div>
        </div>
      </section>

      <!-- FAQ -->
      <section class="mb-20">
        <h2 class="text-2xl font-bold text-center mb-8">Frequently Asked Questions</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <div class="card p-6">
            <h3 class="font-semibold mb-2">What's included in each product?</h3>
            <p class="text-gray-400 text-sm">AI Productivity Suite includes 150+ prompts, templates, and videos. OpenClaw Guide includes 60+ pages of installation methods and troubleshooting.</p>
          </div>
          <div class="card p-6">
            <h3 class="font-semibold mb-2">Is this a subscription?</h3>
            <p class="text-gray-400 text-sm">No. All products are one-time purchases with lifetime updates. Pay once, get every future version.</p>
          </div>
          <div class="card p-6">
            <h3 class="font-semibold mb-2">What if I'm not satisfied?</h3>
            <p class="text-gray-400 text-sm">30-day money-back guarantee on all products. Email us for a full refund — no questions asked.</p>
          </div>
          <div class="card p-6">
            <h3 class="font-semibold mb-2">Can I get both products?</h3>
            <p class="text-gray-400 text-sm">Yes! Many customers get the bundle and save 30%. The products complement each other perfectly.</p>
          </div>
        </div>
      </section>

      <!-- Final CTA -->
      <div class="text-center">
        <h2 class="text-3xl font-bold mb-4">Ready to Work Smarter?</h2>
        <p class="text-gray-400 mb-6">Join 1,500+ professionals saving 10+ hours every week.</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="#productivity" class="px-8 py-4 bg-amber-500 hover:bg-amber-600 text-black font-bold rounded-xl transition-colors">Get AI Productivity Suite</a>
          <a href="#bundle" class="px-8 py-4 bg-gray-700 hover:bg-gray-600 text-white font-bold rounded-xl transition-colors">Get Complete Toolkit</a>
        </div>
        <p class="text-gray-500 text-sm mt-6">🔒 Secure checkout • 📧 Instant delivery • ♻️ 30-day guarantee</p>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
