---
import Layout from '@layouts/Layout.astro';
import Header from '@components/Header.astro';
import Footer from '@components/Footer.astro';

const title = "Payment Successful | Zero Method";
const description = "Thank you for your purchase! Access your AI Productivity Suite download here.";
---

<Layout title={title} description={description}>
  <Header />

  <main class="pt-32 pb-20 min-h-screen">
    <div class="max-w-4xl mx-auto px-6 lg:px-8">
      <!-- Success Card -->
      <div class="text-center mb-12">
        <!-- Success Icon -->
        <div class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-green-500/20 mb-6">
          <svg class="w-10 h-10 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>

        <h1 class="text-4xl sm:text-5xl font-bold text-white mb-4">
          Payment Successful! 🎉
        </h1>
        <p class="text-xl text-navy-300 max-w-2xl mx-auto">
          Welcome to Zero Method. Your AI Productivity Suite is ready.
        </p>
      </div>

      <!-- What's Next Card -->
      <div class="bg-navy-900 rounded-2xl border border-navy-800 p-8 lg:p-12 mb-8">
        <h2 class="text-2xl font-bold text-white mb-6 text-center">
          Here's What Happens Next
        </h2>

        <div class="space-y-6">
          <!-- Step 1 -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/20 flex items-center justify-center flex-shrink-0">
              <span class="text-gold-500 font-bold">1</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-2">Check Your Email</h3>
              <p class="text-navy-400">
                We've sent your download link and getting started guide to your email. 
                It should arrive within 5 minutes. Check your spam folder if you don't see it.
              </p>
            </div>
          </div>

          <!-- Step 2 -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/20 flex items-center justify-center flex-shrink-0">
              <span class="text-gold-500 font-bold">2</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-2">Download the Suite</h3>
              <p class="text-navy-400 mb-4">
                Your complete AI Productivity Suite includes 150+ prompts, 40+ templates, 
                and the full video training course.
              </p>
              
              <a 
                href="mailto:support@thezeromethod.com?subject=Download%20Access%20Request"
                class="inline-flex items-center px-6 py-3 bg-gold-500 hover:bg-gold-600 text-navy-900 font-semibold rounded-lg transition-colors duration-200"
              >
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
                </svg>
                Contact Support for Download Link
              </a>
            </div>
          </div>

          <!-- Step 3 -->
          <div class="flex items-start space-x-4">
            <div class="w-10 h-10 rounded-full bg-gold-500/20 flex items-center justify-center flex-shrink-0">
              <span class="text-gold-500 font-bold">3</span>
            </div>
            <div>
              <h3 class="text-white font-semibold mb-2">Join the Community</h3>
              <p class="text-navy-400 mb-4">
                Connect with 5,000+ productivity hackers, get exclusive tips, and share your wins.
              </p>
              <a 
                href="#"
                class="inline-flex items-center text-gold-500 hover:text-gold-400 font-medium transition-colors"
              >
                Join Private Discord Community
                <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Quick Start Resources -->
      <div class="bg-gradient-to-br from-navy-800 to-navy-900 rounded-2xl border border-navy-700 p-8 mb-8">
        <h2 class="text-xl font-bold text-white mb-6">Quick Start Resources</h2>
        
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <a href="/blog/building-ai-workflow-guide" class="flex items-center p-4 bg-navy-900/50 rounded-xl border border-navy-800 hover:border-gold-500/30 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mr-4">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-medium">Getting Started Guide</h3>
              <p class="text-navy-400 text-sm">7-day setup process</p>
            </div>
          </a>

          <a href="/blog/5-prompts-every-marketer-needs" class="flex items-center p-4 bg-navy-900/50 rounded-xl border border-navy-800 hover:border-gold-500/30 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mr-4">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-medium">Top 5 Prompts</h3>
              <p class="text-navy-400 text-sm">Start with these</p>
            </div>
          </a>

          <a href="mailto:support@thezeromethod.com" class="flex items-center p-4 bg-navy-900/50 rounded-xl border border-navy-800 hover:border-gold-500/30 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mr-4">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-medium">Need Help?</h3>
              <p class="text-navy-400 text-sm">Contact support</p>
            </div>
          </a>

          <a href="/product#faq" class="flex items-center p-4 bg-navy-900/50 rounded-xl border border-navy-800 hover:border-gold-500/30 transition-colors">
            <div class="w-10 h-10 rounded-lg bg-gold-500/10 flex items-center justify-center mr-4">
              <svg class="w-5 h-5 text-gold-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
            <div>
              <h3 class="text-white font-medium">FAQ</h3>
              <p class="text-navy-400 text-sm">Common questions</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Back to Home -->
      <div class="text-center">
        <a
          href="/"
          class="inline-flex items-center text-navy-400 hover:text-white transition-colors"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          Back to Homepage
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>