# Zero Method - Environment Variables Template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# Site URL (for Netlify, use your custom domain)
URL=https://thezeromethod.com

# ============================================
# STRIPE CONFIGURATION
# ============================================

# Stripe Secret Key (NEVER expose this in frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_key_here

# Stripe Publishable Key (safe for frontend)
STRIPE_PUBLISHABLE_KEY=pk_test_your_key_here

# Stripe Webhook Secret (for verifying webhook signatures)
# Get from: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ============================================
# STRIPE PRICE IDs
# Create these in Stripe Dashboard: https://dashboard.stripe.com/products
# ============================================

# Essential Plan ($49)
STRIPE_PRICE_ESSENTIAL=price_1YourEssentialPriceID

# Professional Plan ($79) - Most Popular
STRIPE_PRICE_PROFESSIONAL=price_1YourProfessionalPriceID

# Agency Plan ($149)
STRIPE_PRICE_AGENCY=price_1YourAgencyPriceID

# ============================================
# OPTIONAL INTEGRATIONS
# Uncomment and fill when ready
# ============================================

# Email Service (e.g., Resend, SendGrid, Postmark)
# EMAIL_API_KEY=re_your_api_key_here
# EMAIL_FROM=noreply@thezeromethod.com

# Google Analytics
# GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX

# Supabase (for database if needed)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=your_anon_key_here